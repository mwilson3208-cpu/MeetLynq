# --- Database (PostgreSQL) ---
# Production & dev run on PostgreSQL. For Supabase, copy the "Connection string"
# from Project Settings → Database. Use the pooled connection (port 6543) for the
# app runtime and append ?pgbouncer=true. Example:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# On Vercel with the native Supabase integration you do NOT need DATABASE_URL —
# the integration injects POSTGRES_PRISMA_URL, which the app reads automatically
# (resolution order in src/lib/db.ts: DATABASE_URL → POSTGRES_PRISMA_URL → POSTGRES_URL).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meetlynq"

# --- Auth ---
# Secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET="dev-meetlynq-secret-change-me"

# --- Stripe (payments) ---
# Leave blank to run registration in mock mode (paid tickets complete instantly,
# no real charge). Set these to enable real Stripe Checkout + webhook payments.
# Point a Stripe webhook at /api/webhooks/stripe and subscribe to
# checkout.session.completed and charge.refunded.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Email (Resend / Postmark / SendGrid compatible) ---
EMAIL_PROVIDER="mock"          # mock | resend | postmark | sendgrid
EMAIL_API_KEY=""
EMAIL_FROM="MeetLynq <hello@meetlynq.com>"

# --- AI (OpenAI / Anthropic) ---
AI_PROVIDER="mock"             # mock | anthropic | openai
AI_API_KEY=""

# --- Video meeting hooks ---
VIDEO_PROVIDER="mock"          # mock | daily | zoom | google_meet | teams

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
